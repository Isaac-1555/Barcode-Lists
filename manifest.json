{
  "manifest_version": 3,
  "name": "Barcode Lists",
  "version": "5.7",
  "description": "Store and manage barcode lists with OCR extraction",
  "permissions": [
    "storage",
    "sidePanel",
    "notifications",
    "alarms"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Barcode Lists"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}